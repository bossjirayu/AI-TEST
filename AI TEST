<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transformer Inspection System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; background: #f0f2f5; }
        .gradient-bg { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-md mx-auto bg-white rounded-3xl shadow-2xl overflow-hidden">
        <div class="gradient-bg p-8 text-white text-center">
            <div class="inline-block p-4 bg-white/20 rounded-full mb-4">
                <i class="fas fa-bolt text-4xl text-yellow-300"></i>
            </div>
            <h1 class="text-2xl font-bold uppercase tracking-wide">รายงานการตรวจสอบ</h1>
            <p class="text-blue-100 opacity-80">บำรุงรักษาหม้อแปลงไฟฟ้า</p>
        </div>

        <form id="inspectForm" class="p-6 space-y-5">
            <div>
                <label class="block text-sm font-semibold text-gray-600 mb-1">หมายเลขหม้อแปลง (ID)</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                        <i class="fas fa-tag"></i>
                    </span>
                    <input type="text" id="transformerId" required placeholder="เช่น TR-001"
                        class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-600 mb-1">พิกัดหม้อแปลง (kVA)</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400">
                        <i class="fas fa-microchip"></i>
                    </span>
                    <input type="number" id="rating" required placeholder="ระบุตัวเลขพิกัด"
                        class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-600 mb-1">สถานะ/ผลการตรวจ</label>
                <select id="status" required class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                    <option value="ปกติ (Normal)">🟢 ปกติ (Normal)</option>
                    <option value="เฝ้าระวัง (Warning)">🟡 เฝ้าระวัง (Warning)</option>
                    <option value="ชำรุด (Defective)">🔴 ชำรุด (Defective)</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-600 mb-1">รูปถ่ายหน้างาน</label>
                <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-gray-300 rounded-2xl cursor-pointer hover:bg-gray-50 transition-all overflow-hidden" id="dropzone">
                    <div id="uploadContent" class="flex flex-col items-center justify-center pt-5 pb-6">
                        <i class="fas fa-cloud-upload-alt text-3xl text-gray-400 mb-2"></i>
                        <p class="text-sm text-gray-500">แตะเพื่อเปิดกล้องหรืออัปโหลด</p>
                    </div>
                    <img id="imagePreview" class="hidden w-full h-full object-cover">
                    <input type="file" id="imageFile" accept="image/*" class="hidden">
                </label>
            </div>

            <button type="submit" id="btnSubmit" class="w-full gradient-bg text-white font-bold py-4 rounded-xl shadow-lg hover:opacity-90 transition-all flex items-center justify-center space-x-2">
                <span>ส่งรายงานเข้าระบบ</span>
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>

    <div id="loader" class="fixed inset-0 bg-blue-900/50 backdrop-blur-sm hidden flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-2xl shadow-xl text-center">
            <div class="animate-spin rounded-full h-12 w-12 border-4 border-blue-500 border-t-transparent mx-auto"></div>
            <p class="mt-4 font-semibold text-gray-700">กำลังประมวลผล...</p>
        </div>
    </div>

    <script>
        // วาง Web App URL ที่ได้จาก Google Apps Script ที่นี่
        const scriptUrl = "https://script.google.com/macros/s/AKfycbz7FKjSuRb0Bre0SjaAh8gzYTFPq2uZIQkmXD-W5TLAsfPiZ5Gqa6zG5mMv0wEj857AQg/execนี้"; 

        const fileInput = document.getElementById('imageFile');
        const preview = document.getElementById('imagePreview');
        const uploadContent = document.getElementById('uploadContent');

        // แสดงตัวอย่างรูป
        fileInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    uploadContent.classList.add('hidden');
                }
                reader.readAsDataURL(file);
            }
        });

        // ส่งข้อมูล
        document.getElementById('inspectForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const loader = document.getElementById('loader');
            loader.classList.remove('hidden');

            const file = fileInput.files[0];
            let base64Data = "";
            
            if (file) {
                const reader = new FileReader();
                const promise = new Promise(resolve => {
                    reader.onload = () => resolve(reader.result);
                    reader.readAsDataURL(file);
                });
                base64Data = await promise;
            }

            const formData = {
                transformerId: document.getElementById('transformerId').value,
                rating: document.getElementById('rating').value,
                status: document.getElementById('status').value,
                imageFile: base64Data,
                imageName: file ? file.name : ""
            };

            try {
                const response = await fetch(scriptUrl, {
                    method: 'POST',
                    mode: 'no-cors', // สำคัญสำหรับ Apps Script
                    body: JSON.stringify(formData)
                });

                // เนื่องจากใช้ no-cors เราจะไม่ได้รับ JSON กลับมาตรงๆ 
                // แต่ถ้าไม่มี Error แสดงว่าข้อมูลถูกส่งไปถึงแล้ว
                alert("✅ บันทึกข้อมูลเรียบร้อยแล้ว!");
                document.getElementById('inspectForm').reset();
                preview.classList.add('hidden');
                uploadContent.classList.remove('hidden');
            } catch (err) {
                alert("❌ เกิดข้อผิดพลาด: " + err.message);
            } finally {
                loader.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
